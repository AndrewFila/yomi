{
    "name": "yomi Light",
    "type": "light",
    "colors": {
        "editor.background":                  "#F3EBD8",
        "editor.foreground":                  "#282828",
        "editorCursor.foreground":            "#A33030",
        "editor.selectionBackground":         "#D4C9B0",
        "editor.lineHighlightBackground":     "#E8DEC8",
        "editorLineNumber.foreground":        "#8C8078",
        "editorLineNumber.activeForeground":  "#5C5248",
        "editor.findMatchBackground":         "#8A651855",
        "editor.findMatchHighlightBackground":"#8A651833",

        "activityBar.background":             "#F3EBD8",
        "activityBar.foreground":             "#282828",
        "activityBarBadge.background":        "#2A5890",
        "activityBarBadge.foreground":        "#F9F5EF",

        "sideBar.background":                 "#E8DEC8",
        "sideBar.foreground":                 "#5C5248",
        "sideBarTitle.foreground":            "#282828",
        "sideBarSectionHeader.background":    "#D4C9B0",
        "sideBarSectionHeader.foreground":    "#282828",

        "statusBar.background":               "#D4C9B0",
        "statusBar.foreground":               "#282828",
        "statusBar.noFolderBackground":       "#E8DEC8",
        "statusBarItem.hoverBackground":      "#8C8078",

        "titleBar.activeBackground":          "#F3EBD8",
        "titleBar.activeForeground":          "#282828",
        "titleBar.inactiveBackground":        "#E8DEC8",
        "titleBar.inactiveForeground":        "#8C8078",

        "tab.activeBackground":               "#F3EBD8",
        "tab.activeForeground":               "#282828",
        "tab.inactiveBackground":             "#E8DEC8",
        "tab.inactiveForeground":             "#8C8078",
        "tab.border":                         "#D4C9B0",

        "panel.background":                   "#F3EBD8",
        "panel.border":                       "#D4C9B0",
        "panelTitle.activeForeground":        "#282828",
        "panelTitle.inactiveForeground":      "#8C8078",

        "terminal.background":                "#F3EBD8",
        "terminal.foreground":                "#282828",
        "terminalCursor.foreground":          "#A33030",
        "terminal.ansiBlack":                 "#282828",
        "terminal.ansiRed":                   "#A33030",
        "terminal.ansiGreen":                 "#3A7040",
        "terminal.ansiYellow":                "#8A6518",
        "terminal.ansiBlue":                  "#2A5890",
        "terminal.ansiMagenta":               "#8A2A48",
        "terminal.ansiCyan":                  "#307880",
        "terminal.ansiWhite":                 "#D4C9B0",
        "terminal.ansiBrightBlack":           "#8C8078",
        "terminal.ansiBrightRed":             "#C03838",
        "terminal.ansiBrightGreen":           "#4A8850",
        "terminal.ansiBrightYellow":          "#A07820",
        "terminal.ansiBrightBlue":            "#3A68A8",
        "terminal.ansiBrightMagenta":         "#A83860",
        "terminal.ansiBrightCyan":            "#3A9098",
        "terminal.ansiBrightWhite":           "#F9F5EF",

        "input.background":                   "#E8DEC8",
        "input.foreground":                   "#282828",
        "input.border":                       "#8C8078",
        "focusBorder":                        "#2A5890",

        "list.activeSelectionBackground":     "#D4C9B0",
        "list.activeSelectionForeground":     "#282828",
        "list.hoverBackground":               "#E8DEC8",
        "list.highlightForeground":           "#2A5890",

        "editorGroupHeader.tabsBackground":   "#E8DEC8",
        "editorGroup.border":                 "#D4C9B0",

        "scrollbarSlider.background":         "#D4C9B088",
        "scrollbarSlider.hoverBackground":    "#D4C9B0",
        "scrollbarSlider.activeBackground":   "#8C8078",

        "editorError.foreground":             "#A33030",
        "editorWarning.foreground":           "#8A6518",
        "editorInfo.foreground":              "#2A5890",

        "gitDecoration.addedResourceForeground":    "#3A7040",
        "gitDecoration.modifiedResourceForeground": "#8A6518",
        "gitDecoration.deletedResourceForeground":  "#A33030",
        "gitDecoration.untrackedResourceForeground":"#3A7040",
        "gitDecoration.ignoredResourceForeground":  "#8C8078"
    },
    "tokenColors": [
        {
            "name": "Comment",
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": { "foreground": "#8C8078", "fontStyle": "italic" }
        },
        {
            "name": "String",
            "scope": ["string", "string.quoted"],
            "settings": { "foreground": "#3A7040" }
        },
        {
            "name": "Number / Boolean / Null",
            "scope": ["constant.numeric", "constant.language"],
            "settings": { "foreground": "#A33030" }
        },
        {
            "name": "Keyword",
            "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
            "settings": { "foreground": "#A33030", "fontStyle": "bold" }
        },
        {
            "name": "Operator",
            "scope": ["keyword.operator"],
            "settings": { "foreground": "#307880" }
        },
        {
            "name": "Function",
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#2A5890" }
        },
        {
            "name": "Type",
            "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
            "settings": { "foreground": "#8A6518" }
        },
        {
            "name": "Variable",
            "scope": ["variable", "variable.other"],
            "settings": { "foreground": "#282828" }
        },
        {
            "name": "Parameter",
            "scope": ["variable.parameter"],
            "settings": { "foreground": "#5C5248", "fontStyle": "italic" }
        },
        {
            "name": "Property",
            "scope": ["variable.other.property", "support.variable.property"],
            "settings": { "foreground": "#307880" }
        },
        {
            "name": "Tag",
            "scope": ["entity.name.tag", "meta.tag"],
            "settings": { "foreground": "#A33030" }
        },
        {
            "name": "Attribute",
            "scope": ["entity.other.attribute-name"],
            "settings": { "foreground": "#8A6518" }
        },
        {
            "name": "Preprocessor / Macro",
            "scope": ["meta.preprocessor", "keyword.control.import", "keyword.control.export"],
            "settings": { "foreground": "#8A2A48" }
        },
        {
            "name": "Constant",
            "scope": ["constant", "variable.other.constant"],
            "settings": { "foreground": "#A33030" }
        },
        {
            "name": "Punctuation",
            "scope": ["punctuation"],
            "settings": { "foreground": "#5C5248" }
        }
    ]
}
